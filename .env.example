# Copy to ".env". The DATABASE_URL below matches the bundled docker-compose.yml.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:spynder@localhost:3306/spynder"

# Secret used to sign auth (JWT) cookies. Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Email (optional) ------------------------------------------------------
# Used to send password-reset links. Without these, the reset token is returned
# in-app for local use instead of being emailed.
APP_URL="http://localhost:3000"   # base URL used in reset links
SMTP_HOST=""                       # e.g. smtp.gmail.com / smtp.mailtrap.io
SMTP_PORT="587"                    # 465 for implicit TLS, else 587 (STARTTLS)
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Spynder <no-reply@spynder.app>"

# --- Real catalogues (optional) -------------------------------------------
# Leave blank to use the seeded sample data. Fill in to get live results:
#   Music  -> Spotify   Movies/TV -> TMDB
# Books are live by default via Open Library (free, keyless — no setup needed).
# Each pick is cached into MySQL, so history and the DB fallback keep working.

# Spotify: create an app at https://developer.spotify.com/dashboard
# (Client Credentials flow — no redirect URI needed).
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# TMDB: request a v3 API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""

# Watchmode (optional, movies/series): turns the where-to-watch chips into direct
# deep links to the title on each platform (Netflix, Prime, …). Without it the
# chips stay as plain labels. Free key at https://api.watchmode.com/
WATCHMODE_API_KEY=""
