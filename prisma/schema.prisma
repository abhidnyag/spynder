// Spynder data model — MySQL via Prisma.
// Genres/vibes/providers are stored as JSON arrays (MySQL has no scalar lists),
// which keeps the schema small while remaining query-friendly at this scale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  // PlanetScale (Vitess) has no DB-level foreign keys; Prisma emulates relations.
  // This requires an explicit @@index on every foreign-key column (see below).
  relationMode = "prisma"
}

enum Mode {
  MUSIC
  MOVIE
  BOOK
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  passwordHash String
  createdAt    DateTime       @default(now())
  history      HistoryEntry[]
  favorites    Favorite[]
}

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, suggestionId])
  @@index([userId])
  @@index([suggestionId])
}

model Suggestion {
  id        String         @id @default(cuid()) // external id for API data, e.g. "spotify:<id>"
  mode      Mode
  source    String         @default("seed") // "seed" | "spotify" | "tmdb" | "open_library"
  type      String? // "movie" | "series" (null for music/books)
  title     String
  artist    String? // music: artist · books: author
  year      Int?
  rating    Float? // movies/series · books (avg rating)
  runtime   String? // e.g. "2h 19m" · "Series" · "320 pages"
  synopsis  String?        @db.Text
  genres    Json // string[]
  vibes     Json // string[]
  providers Json? // string[] — where to watch / listen
  url        String? // external link (Spotify / TMDB)
  imageUrl   String? // cover art / poster
  previewUrl String? // 30-sec audio preview (music)
  trailerUrl String? // YouTube trailer (movies/series)
  director   String? // movies/series — director or series creator
  cast       Json? // movies/series — string[] of top-billed actors
  history    HistoryEntry[]
  favorites  Favorite[]

  @@index([mode])
}

model HistoryEntry {
  id           String     @id @default(cuid())
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  userId       String? // null = anonymous session
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String // "suggested" | "saved" | "skipped"
  createdAt    DateTime   @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([suggestionId])
}
